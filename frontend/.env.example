# ============================================================
# Environment Variables — RME Vault Frontend
# ============================================================
# Copy file ini menjadi .env dan isi nilainya
# cp .env.example .env
# ============================================================

# Smart Contract Address (auto-generated by deploy.js)
VITE_CONTRACT_ADDRESS=

# Network Display Name (shown in ConnectWallet)
VITE_CHAIN_NAME=Hardhat Local
VITE_CHAIN_ID=31337

# Pinata IPFS Configuration
# Buat akun di https://app.pinata.cloud
# Buka: https://app.pinata.cloud/developers/api-keys → Create New Key
VITE_PINATA_JWT=your_pinata_jwt_here
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud
